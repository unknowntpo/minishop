{
  "name": "minishop",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.23.0",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "deps:check": "depcruise --config dependency-cruiser.config.cjs app components src db",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run deps:check && pnpm run test",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:reset:dev": "MINISHOP_ALLOW_DB_RESET=1 tsx scripts/reset-dev-db.ts && pnpm db:migrate && pnpm db:seed:dev",
    "db:seed:dev": "tsx scripts/seed-dev-catalog.ts",
    "db:studio": "drizzle-kit studio",
    "benchmark:checkout:postgres:raw": "tsx scripts/benchmark-checkout-postgres.ts",
    "benchmark:checkout:postgres": "tsx scripts/run-checkout-postgres-benchmark.ts",
    "benchmark:checkout:postgres:reset": "BENCHMARK_RESET=1 tsx scripts/run-checkout-postgres-benchmark.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "next": "16.2.4",
    "pg": "^8.20.0",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.10.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "dependency-cruiser": "^17.3.10",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^27.3.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.0.16"
  }
}
