      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 39
      },
      "id": 23,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "((sum by (bucket) (rate(minishop_seckill_bucket_retried_requests_total[1m])) / sum by (bucket) (rate(minishop_seckill_bucket_primary_requests_total[1m]) + rate(minishop_seckill_bucket_retried_requests_total[1m]))) unless (sum by (bucket) (rate(minishop_seckill_bucket_primary_requests_total[1m]) + rate(minishop_seckill_bucket_retried_requests_total[1m])) < 0.05)",
          "legendFormat": "retry ratio {{bucket}}",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "((sum by (bucket) (rate(minishop_seckill_bucket_result_total[1m])) / sum by (bucket) (rate(minishop_seckill_bucket_primary_requests_total[1m]) + rate(minishop_seckill_bucket_retried_requests_total[1m]))) unless (sum by (bucket) (rate(minishop_seckill_bucket_primary_requests_total[1m]) + rate(minishop_seckill_bucket_retried_requests_total[1m])) < 0.05)",
          "legendFormat": "result ratio {{bucket}}",
          "refId": "B"
        }
      ],
      "title": "Per-Bucket Retry and Finalization Ratios",
      "type": "timeseries",
      "description": "Only shows ratios while bucket traffic is materially above zero; hides end-of-run fake spikes."
