    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 15
      },
      "id": 5,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (topic) (kafka_streams_stream_topic_metrics_bytes_produced{topic=~\"inventory\\.seckill\\.(requested|result)|minishop-seckill-worker-v2-.*-changelog\"})",
          "legendFormat": "{{topic}}",
          "refId": "A"
        }
      ],
      "title": "Output Bytes by Sink Topic",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 23
      },
      "id": 20,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(kafka_producer_producer_topic_metrics_record_send_rate{topic=\"inventory.seckill.requested\"}) / clamp_min(sum(kafka_consumer_consumer_fetch_manager_metrics_records_consumed_rate{topic=\"inventory.seckill.requested\"}), 0.0001)",
          "legendFormat": "retry/input ratio",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(kafka_producer_producer_topic_metrics_record_send_rate{topic=\"inventory.seckill.result\"}) / clamp_min(sum(kafka_consumer_consumer_fetch_manager_metrics_records_consumed_rate{topic=\"inventory.seckill.requested\"}), 0.0001)",
          "legendFormat": "result/input ratio",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "(sum(kafka_consumer_consumer_fetch_manager_metrics_records_consumed_rate{topic=\"inventory.seckill.requested\"}) - sum(kafka_producer_producer_topic_metrics_record_send_rate{topic=\"inventory.seckill.result\"})) / clamp_min(sum(kafka_consumer_consumer_fetch_manager_metrics_records_consumed_rate{topic=\"inventory.seckill.requested\"}), 0.0001)",
          "legendFormat": "(input-result)/input",
          "refId": "C"
        }
      ],
      "title": "Retry and Finalization Ratios",
      "type": "timeseries"
    },
    {
