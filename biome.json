{
  "$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
  "files": {
    "includes": [
      "app/**",
      "components/**",
      "db/**",
      "src/**",
      "test/**",
      "*.ts",
      "*.tsx",
      "*.json",
      "!node_modules",
      "!.next",
      "!.pnpm-store",
      "!out",
      "!dist",
      "!coverage",
      "!frontend",
      "!tsconfig.tsbuildinfo"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedImports": "off",
        "noUnusedVariables": "off"
      }
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }
}
